# Sonos Math Alarm Configuration Template

# Active Communication Provider
# Options: "email" or "telegram" (defaults to "email")
PROVIDER="email"

# ==========================================
# Telegram Bot Settings (Required if PROVIDER="telegram")
# ==========================================
# Obtain this token by talking to @BotFather on Telegram
TELEGRAM_BOT_TOKEN="your-bot-token"
# Obtain your chat ID using @userinfobot or similar on Telegram
TELEGRAM_CHAT_ID="your-chat-id"

# ==========================================
# Email Settings (Required if PROVIDER="email")
# ==========================================
# Message Sender (SMTP Settings)
SMTP_SERVER="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-alarm-sender@gmail.com"
# Note: For Gmail/Yahoo, you must use a dedicated App Password if 2FA is active
SMTP_PASSWORD="your-app-password"
SENDER_EMAIL="your-alarm-sender@gmail.com"

# Message Receiver (IMAP Settings)
IMAP_SERVER="imap.gmail.com"
IMAP_PORT=993
IMAP_USERNAME="your-alarm-sender@gmail.com"
IMAP_PASSWORD="your-app-password"

# The user's phone/email address that will receive the problem and reply to it
RECIPIENT_EMAIL="your-personal-email@gmail.com"

# ==========================================
# Sonos Controller Settings
# ==========================================
# Identify your speaker by name or by specific static IP address
SONOS_SPEAKER="Living Room"
# Optional play volume (integer between 0 and 100). If omitted, volume is left unchanged.
# SONOS_VOLUME=30
# Predefined audio track or stream URI (defaults to a public test MP3)
AUDIO_URI="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3"

# Timing and Rules
TIMEOUT_SECONDS=600
CHECK_INTERVAL_SECONDS=10
REPLY_ON_FAILURE=true
